{
  "name": "@nakamacyber/webclaw-mcp",
  "version": "1.6.2",
  "description": "MCP server connecting Claude to markdown vaults on GitHub via WebClaw conventions",
  "type": "module",
  "main": "dist/bundle.mjs",
  "bin": {
    "webclaw-mcp": "dist/bundle.mjs"
  },
  "scripts": {
    "build": "tsc && npm run bundle && npm run bundle:remote",
    "bundle": "esbuild dist/index.js --bundle --platform=node --target=node20 --format=esm --outfile=dist/bundle.mjs",
    "bundle:remote": "esbuild dist/remote.js --bundle --platform=node --target=node20 --format=esm --outfile=dist/remote.mjs --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "dev": "tsc --watch",
    "start": "node dist/bundle.mjs",
    "start:remote": "node dist/remote.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@octokit/rest": "^22.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "author": "NakamaCyber",
  "homepage": "https://webclaw.nakamacyber.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/YourNakama/WebClaw"
  }
}
